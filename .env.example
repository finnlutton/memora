# Memora — environment variables
#
# Copy this file to `.env.local` for local development, or set each value
# in the Vercel dashboard for preview/production deployments. Anything
# prefixed `NEXT_PUBLIC_` ships to the browser; everything else is
# server-only.
#
# Vars marked REQUIRED must be set or the corresponding feature is broken.
# Vars marked PRODUCTION must additionally be set in the Vercel project
# before flipping the production deploy live.

# ---------------------------------------------------------------------------
# Site origin
# ---------------------------------------------------------------------------
# Used for OG metadata, share-link URLs, password-reset redirects.
# Local dev:    http://localhost:3000
# Production:   https://memoragallery.com
# REQUIRED
NEXT_PUBLIC_SITE_URL=

# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------
# Project URL + publishable (anon) key — safe to expose to the browser.
# REQUIRED
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Service-role key — SERVER-ONLY. Used by createSupabaseAdminClient for
# privileged operations (account deletion, share token lookups, admin
# routes). Never expose to the client. Never prefix with NEXT_PUBLIC_.
# REQUIRED + PRODUCTION
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# Stripe
# ---------------------------------------------------------------------------
# Publishable key — browser-safe, used by Stripe.js / Elements.
# REQUIRED
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Secret key — server-only.
# REQUIRED + PRODUCTION
STRIPE_SECRET_KEY=

# Webhook signing secret — used by /api/stripe/webhook to verify event
# authenticity. If unset, every webhook returns 500 and Stripe state will
# silently desync from Memora. Get it from the Stripe webhook endpoint
# settings (different per environment).
# REQUIRED + PRODUCTION
STRIPE_WEBHOOK_SECRET=

# Stripe price IDs for each paid plan. Must match the prices configured
# in your Stripe dashboard. The webhook uses these to map Stripe events
# back to Memora plan IDs.
# REQUIRED + PRODUCTION
STRIPE_PRICE_PLUS_MONTHLY=
STRIPE_PRICE_MAX_MONTHLY=
STRIPE_PRICE_LIFETIME=

# ---------------------------------------------------------------------------
# Google Maps (location autocomplete)
# ---------------------------------------------------------------------------
# Used by the location picker in gallery/subgallery forms. Restrict the
# key to your domains in Google Cloud Console.
# REQUIRED
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ---------------------------------------------------------------------------
# Resend (transactional email)
# ---------------------------------------------------------------------------
# Used for help-feedback delivery. If unset, the help form will fail.
# Domain must be verified in Resend before SUPPORT_EMAIL_FROM works.
# REQUIRED + PRODUCTION
RESEND_API_KEY=
SUPPORT_EMAIL_FROM=support@memoragallery.com
SUPPORT_EMAIL_TO=support@memoragallery.com

# ---------------------------------------------------------------------------
# Admin allowlist
# ---------------------------------------------------------------------------
# Comma-separated emails that may access /admin and /api/admin/*. If
# unset in production, admin tooling is inaccessible (which is safe, but
# means you can't run integrity scans or revoke shares without redeploy).
# PRODUCTION
ADMIN_EMAILS=
